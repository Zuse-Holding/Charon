# ── Search ────────────────────────────────────────────────────────────
SERPER_API_KEY=

# ── LLM Provider ──────────────────────────────────────────────────────
LLM_PROVIDER=         # "groq" | "ollama" | "none" — auto-detected if unset

# ── Groq (recommended — free, fast, no GPU) ───────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Ollama (local fallback) ───────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Supabase ──────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=    # Keep secret — never expose to browser

# ── VPS Agent Server ──────────────────────────────────────────────────
# Set in production when deploying to Vercel + VPS
AGENT_SERVER_URL=             # e.g. https://agents.yourdomain.com
AGENT_SECRET=                 # Random string — shared between Vercel and VPS
AGENT_PORT=4000               # VPS server port
FRONTEND_URL=                 # Your Vercel URL for CORS

# ── Google OAuth (optional — enable in Supabase Dashboard first) ───────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Add to Supabase: Dashboard → Authentication → Providers → Google
